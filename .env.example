# Copy this to .env.local for local dev
# In Netlify: Site Settings → Environment Variables

# Your Modal backend URL (get this after: modal deploy modal_app.py)
VITE_MODAL_API_URL=https://your-username--vton-demo-fastapi-app.modal.run

# Anthropic API key — used client-side to analyze garment images
# Get it from: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-...
